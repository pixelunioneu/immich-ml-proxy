        {
          "expr": "sum by (reason) (rate(immich_ml_proxy_route_fallback_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Upstream Errors by Backend",
      "description": "Requests that failed to reach the chosen backend entirely (connection/timeout failures) - distinct from a successfully-proxied non-2xx response.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
