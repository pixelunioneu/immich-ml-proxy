        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "sum by (backend) (rate(immich_ml_proxy_upstream_errors_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
