      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "process_resident_memory_bytes{namespace=\"immich-ml-proxy\", cluster=~\"$cluster\"}",
          "legendFormat": "{{cluster}}/{{pod}}",
          "refId": "A"
        }
