        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(immich_ml_proxy_request_duration_seconds_bucket{backend=\"default\", cluster=~\"$cluster\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Request Duration Percentiles - OCR Backend",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
